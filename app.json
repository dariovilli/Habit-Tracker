{
  "expo": {
    "name": "Habit Tracker",
    "slug": "antigravity",
    "scheme": "habittracker",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7a4add"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.habittracker.app",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#7a4add"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-router",
      ["expo-notifications", {
        "icon": "./assets/icon.png",
        "color": "#7a4add"
      }],
      ["expo-image-picker", {
        "photosPermission": "Allow Habit Tracker to access your photos to set a profile picture."
      }]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "91c1f3dd-2543-4f0e-9800-c12d5d0c56a6"
      }
    },
    "owner": "radiovilli"
  }
}
